{
  "ml_experiment_type": "fluxnet_parameter_learning_WROASTED",
  "ml_model": {
    "method": "DenseNN",
    "options": {
      "n_layers": 20,
      "n_neurons": 32,
      "k_σ": 3.0,
      "activation_out": "flux_sigmoid",
      "activation_hidden": "flux_relu"
    },
    "package": "Flux"
  },
  "ml_training": {
    "method": "MixedGradient",
    "options": {
      "batch_size": 32,
      "n_epochs": 20,
      "loss_function": "loss_model_obs_machine_learning",
      "split_ratio": [0.2, 0.1],
      "n_folds": 10
    },
    "package": "",
    "fold_path": "./nfolds_sites_indices.jld2",
    "which_fold": 5,
    "pullback_function": "ZygotePullBack"
  },
  "ml_gradient": {
    "method": "Grad",
    "options": {
      "chunk_size": 2
    },
    "package": "ForwardDiff"
  },
  "ml_optimizer": {
    "method": "Adam",
    "options": {
      "η": 0.001,
      "β": [0.9, 0.999],
      "ϵ": 1e-8
    },
    "package": "Optimisers",
    "update_method": "OptimisersUpdate"
  },
  "replace_value_for_gradient": 0.0,
  "save_checkpoint": true,
  "covariates": {
    "path": "https://s3.bgc-jena.mpg.de:9000/sindbad/CovariatesFLUXNET.zarr",
    "options": {
      "kind": "all"
    }
  },

  "random_seed": 2739
}
